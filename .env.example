# This is the login page URL
BANK_BASE_URL="https://digitalinternetbanking.cibeg.com/login"

# Login selectors
BANK_LOGIN_USERNAME_SELECTOR='[data-testid="Username-input"]'
BANK_LOGIN_PASSWORD_SELECTOR='[data-testid="Password-input"]'
BANK_LOGIN_CONTINUE_BUTTON='[data-testid="cib-loginButton"]'
BANK_LOGIN_CAPTCHA_INPUT='[data-testid="undefined-input"], [data-testid="captcha-input"]'
BANK_LOGIN_CAPTCHA_IMAGE='[data-testid="captcha-image"]'
BANK_LOGIN_CAPTCHA_REFRESH='div[tabindex="0"] svg[data-testid="icon"]'

# Already logged in popup
BANK_ALREADY_LOGGED_IN_POPUP='[data-testid="already-logged-in-message"]'
BANK_ALREADY_LOGGED_IN_ACTION_BUTTON='[data-testid="already-logged-in-action-button"]'

# Accounts navigation
BANK_ACCOUNTS_BUTTON='[data-testid="accounts-pressable"]'
BANK_ACCOUNT_CARD='[data-testid$="-pressable"]:not([data-testid="accounts-pressable"])'
BANK_ACCOUNT_NUMBER_SELECTOR='[data-testid="account-number"]'
BANK_ACCOUNT_PRESSABLE_SUFFIX='-pressable'
BANK_ACCOUNT_NAME='[data-testid="account-name"]'
BANK_ACCOUNT_BALANCE='[data-testid="balance"]'
BANK_ACCOUNT_STATUS='[data-testid="status-text"]'

# Transaction export flow
BANK_VIEW_ALL_BUTTON='[data-testid="view-all-button-button"]'
BANK_DOWNLOAD_BUTTON='[data-testid="download-button"]'
BANK_EXPORT_CSV_OPTION='[data-testid="CSV (Spreadsheet)-RadioBox"]'
BANK_EXPORT_CONFIRM_BUTTON='[data-testid="transaction-type-button"]'

# Path to save downloaded files (legacy fallback)
BANK_DOWNLOAD_PATH="./downloads"

# Maximum number of times to attempt login
BANK_MAX_LOGIN_ATTEMPTS=3

# Maximum number of times to attempt captcha
BANK_MAX_CAPTCHA_ATTEMPTS=10

# Gemini Configuration (used for CAPTCHA solving)
GEMINI_API_KEY=your-gemini-api-key-here

# API server (optional)
API_PORT=3000
API_KEY=

## Credentials for CLI/API (or pass in request body)
BANK_USERNAME=
BANK_PASSWORD=
BANK_ACCOUNT_NUMBER=
